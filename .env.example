# Sepolia deployment
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Deployer private key (DO NOT commit .env — it is gitignored)
DEPLOYER_PRIVATE_KEY=0x...

# Optional: override EntryPoint address (defaults to v0.7 canonical address)
# ENTRYPOINT=0x0000000071727De22E5E9d8BAf0edAc6f37da032

# Optional: write deployment addresses to deployments/<chainId>.json
# Set automatically by `make forge-deploy`; omit for dry-runs.
# SAVE_DEPLOY=true
