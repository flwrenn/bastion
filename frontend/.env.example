# Frontend environment variables
# Copy to .env and fill in values.

# --- Required ---

# Pimlico bundler/paymaster API key (used by config.ts). No fallback — set this
# to any free-tier key from https://pimlico.io.
PUBLIC_PIMLICO_API_KEY=your_pimlico_api_key_here

# --- Optional (defaults shown) ---

# Indexer REST/WebSocket base URL (used by indexer.svelte.ts).
# PUBLIC_INDEXER_URL=http://localhost:3001

# Contract addresses override the committed Sepolia values in
# frontend/src/lib/contracts/addresses.ts. Leave these unset to use the defaults;
# set them when pointing the frontend at a different deployment.
# PUBLIC_FACTORY_ADDRESS=0xYOUR_FACTORY_ADDRESS_HERE
# PUBLIC_COUNTER_ADDRESS=0xYOUR_COUNTER_ADDRESS_HERE
# PUBLIC_FAUCET_TOKEN_ADDRESS=0xYOUR_FAUCET_TOKEN_ADDRESS_HERE
