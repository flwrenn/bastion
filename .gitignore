# Environment
.env

# Dependencies
node_modules/

# Contracts
contracts/cache/
contracts/out/
contracts/broadcast/*/31337/
contracts/broadcast/**/dry-run/

# Frontend
.svelte-kit/
frontend/build/
# Generated contract ABIs and addresses — keep the directory but ignore per-ABI
# TypeScript modules. addresses.ts is committed so the frontend has a sensible
# default without requiring PUBLIC_*_ADDRESS env overrides.
frontend/src/lib/contracts/*.ts
!frontend/src/lib/contracts/addresses.ts
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Indexer
indexer/bin/
indexer/indexer

# Local
tmp/
.DS_Store
